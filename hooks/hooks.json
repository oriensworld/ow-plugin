{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ow-plugin] Session started at $(date -Iseconds)\" >> \"${HOME}/ow-plugin.log\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ow-plugin] File modified at $(date -Iseconds)\""
          }
        ]
      }
    ]
  }
}
